override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Secrets / keys
*.pem
*.key
*.ppk
*.rdp

# OS/editor files
.DS_Store
Thumbs.db
.vscode/

# Real backend config
backend.tf
!backend.tf.example